# AquaRythu — required environment variables
#
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env — it is gitignored.
#
# For APK/AAB builds, pass these via --dart-define (see scripts/build_release_apk.sh).
# For CI/CD, store as repository secrets.

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_<your-anon-key>

# ── Razorpay ────────────────────────────────────────────────────────────────
# Test key:       rzp_test_xxxxxxxxxxxx
# Production key: rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_<test_or_live>_xxxxxxxxxxxx
